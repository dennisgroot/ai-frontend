<header class="w-full bg-[#1B1B3A]">
  <div class="flex flex-col md:flex-row gap-0 md:gap-5">
    <!-- Left Column -->
    <div class="w-full md:w-1/2 flex flex-col">
      <div class="relative flex flex-col items-end justify-center min-h-[629px] py-[69px] px-5 md:px-20">
        <!-- Background Image -->
        <img src="https://placehold.co/1200x800/1B1B3A/white" 
             class="absolute inset-0 w-full h-full object-cover object-center" 
             alt="Header background">
        
        <!-- Content Container -->
        <div class="relative flex flex-col items-start justify-start w-full md:w-[683px] max-w-full">
          <!-- Title -->
          <h1 class="text-white text-4xl md:text-[66px] font-semibold leading-[49px] md:leading-[72px] font-inter self-stretch">
            Onafhankelijke en betrouwbare informatie over de schildklier
          </h1>
          
          <!-- Search Box -->
          <div class="relative flex items-start justify-start bg-white rounded-[10px] mt-8 min-h-[79px] w-full md:w-[641px] max-w-full py-6 px-5 md:px-7">
            <div class="text-[#5a5a5a] text-xl font-medium leading-normal font-inter my-auto">
              Waar ben je naar op zoek?
            </div>
            
            <!-- Search Button -->
            <div class="absolute right-[9px] bottom-[9px] flex items-center justify-center bg-[#694f9c] rounded-[10px] w-[60px] h-[60px] p-5">
              <img src="{{ '/assets/img/search-icon.svg' | url }}" 
                   class="w-[19px] object-contain self-stretch my-auto" 
                   alt="Search">
            </div>
          </div>
          
          <!-- Popular Terms -->
          <div class="flex flex-wrap items-center justify-center gap-[18px] mt-8 p-[10px] text-white text-base font-normal leading-8 font-inter max-w-full">
            <div class="self-stretch my-auto">Populaire zoektermen: </div>
            <div class="self-stretch my-auto underline cursor-pointer">Zwangerschap</div>
            <div class="self-stretch my-auto underline cursor-pointer">Voeding</div>
            <div class="self-stretch my-auto underline cursor-pointer">Schildkliertelefoon</div>
          </div>
        </div>
      </div>
    </div>
    
    <!-- Right Column -->
    <div class="w-full md:w-1/2 md:ml-5">
      <img src="https://placehold.co/800x600/CCCCCC/333333" 
           class="w-full aspect-[1.33] object-contain object-center flex-grow" 
           alt="Featured image">
    </div>
  </div>
</header>
