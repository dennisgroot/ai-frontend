<section class="item-list wp-block alignfull {{ className }}">
    <div class="row">
        <div class="column small-12 large-6">
            <div class="r-mb-m">
                <h2 class="h2 item-list__title">{{ blockTitle }}</h2>
                <div class="item-list__intro">
                    <p data-fakerjs="sentences|3|6"></p>
                </div>
            </div>
        </div>
    </div>
    <div class="row small-up-1 medium-up-2 large-up-3 flex-grow">
        {% for item in [0,1,2] %}
        <div class="column">
            <a href="#" class="card grow {{ cardClass }}">
                <template x-if="image == true">
                    <img loading="lazy" class="card__image lazyload aspect-[6/4]" src="https://placehold.co/600x400/{{ color }}/svg" alt="Landscape" />
                </template>
                <div class="card__content grow">
                    <div class="card__date">12 april 2023</div>
                    <h3 class="h4 card__title">Lorem ipsum dolor sit amet,
                        consectetur adipiscing elit,</h3>
                    <div class="card__text text-grow">
                        <p data-fakerjs="sentences|3|6"></p>
                    </div>
                    <button class="button card__button">Lees verder</button>
                </div>
            </a>
        </div>
        {% endfor %}
    </div>
</section>