<section class="events wp-block alignfull {{className}}">
    <div class="row">
        <div class="large-6 column">
            <div class="r-mb-m">
                <h2 class="h2 events__title">{{ blockTitle }}</h2>
                <div class="events__intro">
                    <p data-fakerjs="sentences|3|6"></p>
                </div>
            </div>
        </div>
    </div>
    <div class="row small-up-1 medium-up-2 large-up-3 flex-grow">
        {% for item in [0,1,2] %}
        <div class="column">
            <a href="#" class="card card--event card--white grow">
                <div class="card__image-wrapper">
                    <img loading="lazy" class="card__image lazyload aspect-[12/8]" src="https://placehold.co/600x400/{{color}}/white/svg" title="#" alt="Landscape" />
                    <div data-fakerjs="date" class="card__event-date"></div>
                </div>
                <div class="card__content grow">
                    <h3 class="h4 card__title" data-fakerjs="words|5|6"></h3>
                    <div class="card__text text-grow">
                        <p data-fakerjs="sentences|2|3"></p>
                    </div>
                    <div class="card__link">Bekijk het evenement</div>
                </div>
            </a>
        </div>
        {% endfor %}
    </div>
</section>