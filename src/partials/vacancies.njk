<section class="vacancies wp-block alignfull {{className}}">
    <div class="row">
        <div class="large-6 column">
            <div class="r-mb-m">
                <h2 class="h2 vacancies__title">{{ blockTitle }}</h2>
                <div class="vacancies__intro">
                    <p data-fakerjs="sentences|3|6"></p>
                </div>
            </div>
        </div>
    </div>
    <div class="row small-up-1 medium-up-2 large-up-3 flex-grow">
        {% for item in [0,1,2] %}
        <article class="column">
            <a href="#" class="card card--event card--white grow">
                <div class="card__content grow">
                    <div class="card__vacancy-info">
                        32 uur per week
                    </div>
                    <h3 class="h3 card__title" data-fakerjs="words|5|6"></h3>
                    <div class="card__text text-grow">
                        <p data-fakerjs="sentences|2|3"></p>
                    </div>
                    <div class="card__link">Bekijk de vacature</div>
                </div>
            </a>
        </article>
        {% endfor %}
    </div>
</section>